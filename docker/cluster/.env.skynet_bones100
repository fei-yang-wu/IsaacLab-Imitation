# Skynet profile for the BONES-SEED-100 pretrain + low-level IPMD 2B job.
# Used via: ./docker/cluster/cluster_interface.sh -c skynet_bones100 job ...
# Dataset must be pre-staged at ${CLUSTER_DATA_DIR}/bones_seed_100 (npz are rsync-excluded).
CLUSTER_JOB_SCHEDULER=SLURM
CLUSTER_LOGIN=skynet
CLUSTER_ISAACLAB_DIR=/coc/flash12/fwu91/Research/IsaacLab/isaaclab
CLUSTER_SIF_PATH=/coc/flash12/fwu91/Research/IsaacLab/isaaclabsif
CLUSTER_DATA_DIR=/coc/flash12/fwu91/Research/IsaacLab/data
CLUSTER_ISAAC_SIM_CACHE_DIR=/coc/flash12/fwu91/Research/IsaacLab/cache
CLUSTER_AUTO_SETUP_G1_DATA=0
CLUSTER_APPEND_DEFAULT_G1_MANIFEST=0
CLUSTER_G1_MANIFEST_REFRESH_POLICY=never
CLUSTER_HF_TOKEN_FILE=/nethome/fwu91/.hf_token
CLUSTER_WANDB_API_KEY_FILE=/nethome/fwu91/.wandb_api_key
CLUSTER_PYTHON_EXECUTABLE=scripts/rlopt/run_bones_seed_100_pretrain_lowlevel.py
CLUSTER_PIXI_ENV=isaaclab
CLUSTER_PIXI_CACHE_DIR=/coc/flash12/fwu91/Research/IsaacLab/pixi-cache
CLUSTER_SKIP_SINGULARITY_IMAGE_CHECK=1
CLUSTER_RLOPT_LOCAL_PATH=/mnt/hsstorage/fwu91/Projects/SL/IsaacLab-Imitation/RLOpt
CLUSTER_IMITATION_TOOLS_LOCAL_PATH=/mnt/hsstorage/fwu91/Projects/SL/IsaacLab-Imitation/ImitationLearningTools
CLUSTER_EXTRA_PYTHONPATH_REL=IsaacLab/source/isaaclab:IsaacLab/source/isaaclab_tasks:IsaacLab/source/isaaclab_assets:IsaacLab/source/isaaclab_rl:IsaacLab/source/isaaclab_mimic:source/isaaclab_imitation:RLOpt:ImitationLearningTools
CLUSTER_SLURM_SUBMIT_SCRIPT=skynet_pixi
CLUSTER_SLURM_PARTITION=wu-lab
CLUSTER_SLURM_NODELIST=dendrite,synapse
CLUSTER_SLURM_QOS=short
CLUSTER_SLURM_GPU_GRES=gpu:a40:1
CLUSTER_SLURM_CPUS_PER_TASK=8
CLUSTER_SLURM_MEM=96G
CLUSTER_SLURM_TIME_LIMIT=2-00:00:00
CLUSTER_SLURM_JOB_NAME_PREFIX=bones100-2b
CLUSTER_SLURM_OUTPUT_DIR=logs/slurm
CLUSTER_SLURM_PRINT_JOB_SCRIPT=1
CLUSTER_JOB_TMPDIR_ROOT=/tmp
REMOVE_CODE_COPY_AFTER_JOB=false
REMOVE_OVERLAY_AFTER_JOB=true
